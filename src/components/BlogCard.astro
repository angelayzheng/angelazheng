---
import "../styles/global.css";

const { url, frontmatter } = Astro.props;
---

<article
  class="mx-auto w-full max-w-4xl border-b border-lilac/35 py-4 md:py-5 first:border-t first:border-lilac/35"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[9rem,1fr] md:gap-5 gap-2.5 items-start"
  >
    <div
      class="text-[0.7rem] md:text-xs uppercase tracking-[0.14em] text-teal dark:text-aquamarine md:pt-0.5"
    >
      {
        new Date(frontmatter.date).toLocaleDateString("en-CA", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </div>

    <div class="flex flex-col gap-2 md:gap-2.5">
      <h2
        class="text-xl md:text-2xl leading-tight font-semibold text-eggplant dark:text-lilac"
      >
        <a href={url} class="hover:underline decoration-2 underline-offset-4">
          {frontmatter.title}
        </a>
      </h2>

      <p
        class="text-sm md:text-base leading-relaxed text-dark/80 dark:text-light/80"
      >
        {frontmatter.description}
      </p>

      {
        frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 pt-0.5">
            {frontmatter.tags.map((tag: string) => (
              <span class="rounded-full border border-rose/25 dark:border-salmon/35 px-2 py-0.5 text-[0.7rem] text-rose dark:text-salmon">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</article>
