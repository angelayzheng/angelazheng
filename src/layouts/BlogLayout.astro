---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Prose from "../components/Prose.astro";

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <article class="my-6 md:my-12 px-4">
    <div class="mx-auto w-full max-w-3xl">
      <a
        href="/blog"
        class="inline-flex items-center gap-1 text-sm md:text-base text-rose dark:text-salmon"
      >
        <span aria-hidden="true">&larr;</span><span class="hover:underline">
          Back to Blog</span
        >
      </a>

      <header class="mt-5 md:mt-7 border-b border-lilac/35 pb-6 md:pb-8">
        <p
          class="text-xs md:text-sm uppercase tracking-[0.14em] text-teal dark:text-aquamarine"
        >
          {
            new Date(frontmatter.date).toLocaleDateString("en-CA", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </p>

        <h1
          class="mt-3 text-3xl md:text-5xl font-semibold leading-tight text-eggplant dark:text-lilac"
        >
          {frontmatter.title}
        </h1>

        <p
          class="mt-3 md:mt-4 italic text-sm md:text-base text-dark/75 dark:text-light/80"
        >
          {frontmatter.description}
        </p>

        {
          frontmatter.tags && frontmatter.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {frontmatter.tags.map((tag: string) => (
                <span class="rounded-full border border-rose/25 dark:border-salmon/35 px-2.5 py-0.5 text-xs text-rose dark:text-salmon">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      <Prose class="mt-8 md:mt-10 max-w-none prose-h1:text-left px-0">
        <slot />
      </Prose>
    </div>
  </article>
</Layout>
